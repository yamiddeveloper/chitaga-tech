---
import ScrollAnimation from './ScrollAnimation.jsx';
import { getAllEvents } from '../data/events.js';
import type { Event } from '../types/events';

const allEvents = getAllEvents();
const cardVariants = {
    hidden: { opacity: 0, y: 40 },
    visible: { opacity: 1, y: 0 }
};
---

<section id="eventos" class="events-section">
    <div class="events-inner">
        <ScrollAnimation className="events-header" delay={0.2} client:load as="div">
            <span class="events-badge">Talleres Tech</span>
            <h2 class="events-title">Próximos eventos y talleres</h2>
            <p class="events-subtitle">Participa en nuestros talleres prácticos y aprende habilidades tecnológicas con expertos de la comunidad.</p>
        </ScrollAnimation>

        {allEvents.length > 0 ? (
            <div class="events-grid">
                {allEvents.map((event: Event, index: number) => (
                    <ScrollAnimation
                        delay={0.3 + index * 0.1}
                        variants={cardVariants}
                        client:load
                        as="div"
                    >
                        {event.status === 'open' ? (
                            <div class="event-card">
                                <div class="event-image">
                                    {event.image ? (
                                        <img 
                                            src={event.image} 
                                            alt={event.title}
                                            loading="lazy"
                                            decoding="async"
                                            style="image-rendering: auto; image-rendering: -webkit-optimize-contrast;"
                                        />
                                    ) : (
                                        <div class="event-image-placeholder">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                                <polyline points="21 15 16 10 5 21"></polyline>
                                            </svg>
                                        </div>
                                    )}
                                    {event.badge && (
                                        <span class="event-badge">{event.badge}</span>
                                    )}
                                </div>
                                <div class="event-body">
                                    <h3>{event.title}</h3>
                                    <p>{event.description}</p>
                                    
                                    <div class="event-details">
                                        <div class="event-detail">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                            </svg>
                                            <span>{event.date}</span>
                                        </div>
                                        <div class="event-detail">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                            <span>{event.time}</span>
                                        </div>
                                        <div class="event-detail">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                                <circle cx="12" cy="10" r="3"></circle>
                                            </svg>
                                            <span>{event.location}</span>
                                        </div>
                                    </div>
                                    
                                    <div class="event-actions">
                                        <a href={`/evento/${event.slug}/`} class="event-button">
                                            Inscribirme
                                        </a>
                                        <div class="event-capacity">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                                <circle cx="9" cy="7" r="4"></circle>
                                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                                            </svg>
                                            <span>{event.capacity} cupos</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ) : (
                            <div class="finished-event-card">
                                <div class="finished-event-image">
                                    {event.image ? (
                                        <img 
                                            src={event.image} 
                                            alt={event.title}
                                            loading="lazy"
                                            decoding="async"
                                            style="image-rendering: auto; image-rendering: -webkit-optimize-contrast;"
                                        />
                                    ) : (
                                        <div class="finished-event-image-placeholder">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                                <polyline points="21 15 16 10 5 21"></polyline>
                                            </svg>
                                        </div>
                                    )}
                                    {event.badge && (
                                        <span class="finished-event-badge">{event.badge}</span>
                                    )}
                                </div>
                                <div class="finished-event-body">
                                    <h3>{event.title}</h3>
                                    <p>{event.description}</p>
                                    
                                    <div class="finished-event-details">
                                        <div class="finished-event-detail">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                            </svg>
                                            <span>{event.date}</span>
                                        </div>
                                        <div class="finished-event-detail">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="12" r="10"></circle>
                                                <polyline points="12 6 12 12 16 14"></polyline>
                                            </svg>
                                            <span>{event.time}</span>
                                        </div>
                                    </div>
                                    
                                    <div class="finished-event-status">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>Evento completado</span>
                                    </div>
                                </div>
                            </div>
                        )}
                    </ScrollAnimation>
                ))}
            </div>
        ) : (
            <div class="events-empty">
                <div class="events-empty-icon">📅</div>
                <h3>No hay eventos programados</h3>
                <p>Pronto anunciaremos nuevos talleres y eventos. ¡Mantente atento!</p>
            </div>
        )}
    </div>
</section>

<style>
    .events-section {
        padding: 5rem 2rem;
        background: #f9fafb;
    }

    :global(.dark) .events-section {
        background: #1a1a1a;
    }

    @media (min-width: 768px) {
        .events-section {
            padding: 6rem 3rem;
        }
    }

    @media (min-width: 1024px) {
        .events-section {
            padding: 8rem 4rem;
        }
    }

    .events-inner {
        max-width: 1200px;
        display: grid;
        gap: 2rem;
        margin: 0 auto;
    }

    :global(.events-header) {
        text-align: center;
        margin-bottom: 3.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
    }

    .events-badge {
        display: inline-block;
        width: fit-content;
        padding: 0.3rem 0.85rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 9999px;
        color: var(--color-orange);
        border: 1px solid var(--color-orange);
        font-family: var(--font-pop);
    }

    .events-title {
        font-family: var(--font-montserrat);
        font-weight: 700;
        font-size: 1.75rem;
        line-height: 1.2;
        color: var(--color-green-dark);
    }

    :global(.dark) .events-title {
        color: var(--color-white);
    }

    @media (min-width: 768px) {
        .events-title {
            font-size: 2.25rem;
        }
    }

    .events-subtitle {
        font-family: var(--font-sans);
        font-size: 1rem;
        line-height: 1.7;
        color: #6b7280;
        max-width: 520px;
    }

    :global(.dark) .events-subtitle {
        color: #9ca3af;
    }

    .events-grid {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .events-grid > * {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    @media (min-width: 640px) {
        .events-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            align-items: stretch;
        }
    }

    @media (min-width: 1024px) {
        .events-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
    }

    .event-card {
        border-radius: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #ffffff;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    :global(.dark) .event-card {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.08);
    }

    .event-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    }

    :global(.dark) .event-card:hover {
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    }

    .event-image {
        width: 100%;
        height: 180px;
        position: relative;
        overflow: hidden;
    }

    .event-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        image-rendering: auto;
        image-rendering: -webkit-optimize-contrast;
        backface-visibility: hidden;
        transform: translateZ(0);
        -webkit-transform: translateZ(0);
        -webkit-font-smoothing: antialiased;
        filter: contrast(1.08) brightness(1.03) saturate(1.05);
        image-resolution: 300dpi;
        -webkit-interpolation-mode: bicubic;
        image-rendering: smooth;
    }

    .event-image-placeholder {
        width: 100%;
        height: 100%;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
    }

    :global(.dark) .event-image-placeholder {
        background: rgba(255, 255, 255, 0.06);
        color: #6b7280;
    }

    .event-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.25rem 0.75rem;
        font-size: 0.7rem;
        font-weight: 600;
        border-radius: 9999px;
        background: var(--color-orange);
        color: white;
        font-family: var(--font-pop);
    }

    .event-body {
        padding: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex: 1;
    }

    .event-body h3 {
        font-family: var(--font-montserrat);
        font-weight: 600;
        font-size: 1.05rem;
        color: var(--color-green-dark);
        line-height: 1.3;
    }

    :global(.dark) .event-body h3 {
        color: var(--color-white);
    }

    .event-body p {
        font-family: var(--font-sans);
        font-size: 0.875rem;
        line-height: 1.65;
        color: #6b7280;
        flex: 1;
    }

    :global(.dark) .event-body p {
        color: #9ca3af;
    }

    .event-details {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .event-detail {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        color: #6b7280;
    }

    :global(.dark) .event-detail {
        color: #9ca3af;
    }

    .event-detail svg {
        flex-shrink: 0;
        color: var(--color-orange);
    }

    .event-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    :global(.dark) .event-actions {
        border-top-color: rgba(255, 255, 255, 0.08);
    }

    .event-button {
        padding: 0.5rem 1.25rem;
        font-family: var(--font-pop);
        font-weight: 600;
        font-size: 0.85rem;
        color: white;
        background: var(--color-orange);
        border-radius: 0.5rem;
        text-decoration: none;
        transition: background-color 0.2s ease;
    }

    .event-button:hover {
        background: #d25d29;
    }

    .event-capacity {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        color: #6b7280;
    }

    :global(.dark) .event-capacity {
        color: #9ca3af;
    }

    .event-capacity svg {
        color: var(--color-orange);
    }

    .events-empty {
        text-align: center;
        padding: 3rem 1rem;
        background: rgba(255, 255, 255, 0.5);
        border-radius: 1rem;
        border: 2px dashed rgba(0, 0, 0, 0.1);
    }

    :global(.dark) .events-empty {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.1);
    }

    .events-empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .events-empty h3 {
        font-family: var(--font-montserrat);
        font-weight: 600;
        font-size: 1.25rem;
        color: var(--color-green-dark);
        margin-bottom: 0.5rem;
    }

    :global(.dark) .events-empty h3 {
        color: var(--color-white);
    }

    .events-empty p {
        font-family: var(--font-sans);
        font-size: 0.95rem;
        color: #6b7280;
        max-width: 400px;
        margin: 0 auto;
    }

    :global(.dark) .events-empty p {
        color: #9ca3af;
    }

    /* Estilos para eventos pasados */
    .finished-events-section {
        margin-top: 4rem;
        padding-top: 3rem;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
    }

    :global(.dark) .finished-events-section {
        border-top-color: rgba(255, 255, 255, 0.1);
    }

    :global(.finished-events-header) {
        text-align: center;
        margin-bottom: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }

    .finished-events-title {
        font-family: var(--font-montserrat);
        font-weight: 600;
        font-size: 1.5rem;
        color: var(--color-green-dark);
    }

    :global(.dark) .finished-events-title {
        color: var(--color-white);
    }

    .finished-events-subtitle {
        font-family: var(--font-sans);
        font-size: 0.95rem;
        line-height: 1.6;
        color: #6b7280;
        max-width: 480px;
    }

    :global(.dark) .finished-events-subtitle {
        color: #9ca3af;
    }

    .finished-events-grid {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .finished-events-grid > * {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    @media (min-width: 640px) {
        .finished-events-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
            align-items: stretch;
        }
    }

    @media (min-width: 1024px) {
        .finished-events-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
    }

    .finished-event-card {
        border-radius: 1rem;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: #ffffff;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        opacity: 0.85;
        transition: opacity 0.3s ease, transform 0.3s ease;
    }

    :global(.dark) .finished-event-card {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.08);
    }

    .finished-event-card:hover {
        opacity: 1;
        transform: translateY(-2px);
    }

    .finished-event-image {
        width: 100%;
        height: 160px;
        position: relative;
        overflow: hidden;
        filter: grayscale(20%);
    }

    .finished-event-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        image-rendering: auto;
        image-rendering: -webkit-optimize-contrast;
        backface-visibility: hidden;
        transform: translateZ(0);
        -webkit-transform: translateZ(0);
        -webkit-font-smoothing: antialiased;
        filter: contrast(1.05) brightness(0.95);
        image-resolution: 300dpi;
        -webkit-interpolation-mode: bicubic;
        image-rendering: smooth;
    }

    .finished-event-image-placeholder {
        width: 100%;
        height: 100%;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
    }

    :global(.dark) .finished-event-image-placeholder {
        background: rgba(255, 255, 255, 0.06);
        color: #6b7280;
    }

    .finished-event-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        padding: 0.25rem 0.75rem;
        font-size: 0.7rem;
        font-weight: 600;
        border-radius: 9999px;
        background: #6b7280;
        color: white;
        font-family: var(--font-pop);
    }

    :global(.dark) .finished-event-badge {
        background: #4b5563;
    }

    .finished-event-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .finished-event-body h3 {
        font-family: var(--font-montserrat);
        font-weight: 600;
        font-size: 1rem;
        color: var(--color-green-dark);
        line-height: 1.3;
    }

    :global(.dark) .finished-event-body h3 {
        color: var(--color-white);
    }

    .finished-event-body p {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        line-height: 1.6;
        color: #6b7280;
        flex: 1;
    }

    :global(.dark) .finished-event-body p {
        color: #9ca3af;
    }

    .finished-event-details {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        margin-top: 0.5rem;
    }

    .finished-event-detail {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-size: 0.75rem;
        color: #6b7280;
    }

    :global(.dark) .finished-event-detail {
        color: #9ca3af;
    }

    .finished-event-detail svg {
        flex-shrink: 0;
        color: #6b7280;
    }

    :global(.dark) .finished-event-detail svg {
        color: #9ca3af;
    }

    .finished-event-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-size: 0.8rem;
        color: #10b981;
        margin-top: 0.5rem;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    :global(.dark) .finished-event-status {
        color: #34d399;
        border-top-color: rgba(255, 255, 255, 0.08);
    }

    .finished-event-status svg {
        color: #10b981;
    }

    :global(.dark) .finished-event-status svg {
        color: #34d399;
    }
</style>