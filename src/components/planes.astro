---
import ScrollAnimation from './ScrollAnimation.jsx';
---

<section id="planes" class="planes-section">
    <script is:inline>
        (function() {
            var type = localStorage.getItem('visitor-type');
            if (type === 'business') {
                document.body.classList.add('visitor-business');
                document.addEventListener('DOMContentLoaded', function() {
                    var section = document.getElementById('planes');
                    if (section) section.classList.add('show-section');
                });
            }
        })();
    </script>
    <div class="planes-inner">
        <ScrollAnimation className="planes-header" delay={0.1} client:load as="div">
            <span class="planes-badge">Planes para tu negocio</span>
            <h2 class="planes-title">Elige el plan perfecto para llevar tu negocio al mundo digital</h2>
            <p class="planes-description">
                Desarrollado con talento chitagüense. Cada plan incluye diseño personalizado, soporte y alojamiento web.
            </p>
        </ScrollAnimation>

        <div class="plans-grid">
            <ScrollAnimation delay={0.2} client:load as="div">
                <div class="plan-card">
                    <div class="plan-header">
                        <h3 class="plan-name">Básico</h3>
                        <div class="plan-price">
                            <span class="plan-currency">$</span>
                            <span class="plan-amount">150.000</span>
                            <span class="plan-period">COP</span>
                        </div>
                        <p class="plan-tagline">Ideal para empezar</p>
                    </div>
                    <ul class="plan-features">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Página de una sola sección (one-page)
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Diseño responsivo (móvil y escritorio)
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Formulario de contacto
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Enlace a redes sociales
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Alojamiento por 1 año
                        </li>
                    </ul>
                    <a href="#contacto" class="plan-cta plan-cta-outline">Quiero este plan</a>
                </div>
            </ScrollAnimation>

            <ScrollAnimation delay={0.3} client:load as="div">
                <div class="plan-card plan-card-featured">
                    <div class="plan-popular-badge">Más popular</div>
                    <div class="plan-header">
                        <h3 class="plan-name">Profesional</h3>
                        <div class="plan-price">
                            <span class="plan-currency">$</span>
                            <span class="plan-amount">350.000</span>
                            <span class="plan-period">COP</span>
                        </div>
                        <p class="plan-tagline">Para negocios en crecimiento</p>
                    </div>
                    <ul class="plan-features">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Hasta 5 páginas internas
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Diseño personalizado con tu marca
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Galería de productos o servicios
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Optimización SEO básica
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Integración con WhatsApp
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Alojamiento por 1 año
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Soporte por 6 meses
                        </li>
                    </ul>
                    <a href="#contacto" class="plan-cta plan-cta-filled">Quiero este plan</a>
                </div>
            </ScrollAnimation>

            <ScrollAnimation delay={0.4} client:load as="div">
                <div class="plan-card">
                    <div class="plan-header">
                        <h3 class="plan-name">Premium</h3>
                        <div class="plan-price">
                            <span class="plan-currency">$</span>
                            <span class="plan-amount">700.000</span>
                            <span class="plan-period">COP</span>
                        </div>
                        <p class="plan-tagline">Solución completa</p>
                    </div>
                    <ul class="plan-features">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Sitio web ilimitado de páginas
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Diseño premium a medida
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Tienda en línea (e-commerce)
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Panel administrable
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            SEO avanzado + Google Analytics
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Alojamiento por 2 años
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Soporte prioritario por 1 año
                        </li>
                    </ul>
                    <a href="#contacto" class="plan-cta plan-cta-outline">Quiero este plan</a>
                </div>
            </ScrollAnimation>
        </div>
    </div>
</section>

<style>
    .planes-section {
        display: none;
        padding: 5rem 2rem;
        background: #f9fafb;
    }

    .planes-section.show-section {
        display: block;
    }

    :global(.dark) .planes-section {
        background: #111111;
    }

    .planes-inner {
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Header */
    :global(.planes-header) {
        text-align: center;
        max-width: 680px;
        margin: 0 auto 3.5rem;
    }

    .planes-badge {
        display: inline-block;
        padding: 0.3rem 0.85rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 9999px;
        color: var(--color-green-dark);
        border: 1px solid var(--color-green-dark);
        font-family: var(--font-pop);
        margin-bottom: 1rem;
    }

    :global(.dark) .planes-badge {
        color: var(--color-orange);
        border-color: var(--color-orange);
    }

    .planes-title {
        font-family: var(--font-montserrat);
        font-weight: 700;
        font-size: 2rem;
        line-height: 1.2;
        color: var(--color-green-dark);
        margin-bottom: 1rem;
    }

    :global(.dark) .planes-title {
        color: var(--color-white);
    }

    @media (min-width: 768px) {
        .planes-title {
            font-size: 2.5rem;
        }
    }

    .planes-description {
        font-family: var(--font-sans);
        font-size: 1.05rem;
        line-height: 1.7;
        color: #6b7280;
    }

    :global(.dark) .planes-description {
        color: #9ca3af;
    }

    /* Grid */
    .plans-grid {
        display: grid;
        gap: 1.5rem;
        grid-template-columns: 1fr;
        align-items: stretch;
    }

    @media (min-width: 768px) {
        .plans-grid {
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
    }

    .plans-grid > div {
        height: 100%;
    }

    /* Card */
    .plan-card {
        background: #ffffff;
        border-radius: 1rem;
        padding: 2rem;
        border: 1px solid #e5e7eb;
        display: flex;
        flex-direction: column;
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        height: 100%;
    }

    .plan-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    }

    :global(.dark) .plan-card {
        background: #1a1a1a;
        border-color: #2a2a2a;
    }

    .plan-card-featured {
        border-color: var(--color-orange);
        border-width: 2px;
    }

    :global(.dark) .plan-card-featured {
        border-color: var(--color-orange);
    }

    .plan-popular-badge {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--color-orange);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.3rem 1rem;
        border-radius: 9999px;
        font-family: var(--font-pop);
    }

    /* Plan header */
    .plan-header {
        text-align: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e5e7eb;
    }

    :global(.dark) .plan-header {
        border-bottom-color: #2a2a2a;
    }

    .plan-name {
        font-family: var(--font-montserrat);
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--color-green-dark);
        margin-bottom: 0.75rem;
    }

    :global(.dark) .plan-name {
        color: var(--color-white);
    }

    .plan-price {
        display: flex;
        align-items: baseline;
        justify-content: center;
        gap: 2px;
        margin-bottom: 0.5rem;
    }

    .plan-currency {
        font-family: var(--font-montserrat);
        font-size: 1rem;
        font-weight: 600;
        color: #6b7280;
    }

    .plan-amount {
        font-family: var(--font-montserrat);
        font-size: 2.25rem;
        font-weight: 800;
        color: var(--color-green-dark);
        line-height: 1;
    }

    :global(.dark) .plan-amount {
        color: var(--color-white);
    }

    .plan-period {
        font-family: var(--font-pop);
        font-size: 0.8rem;
        font-weight: 600;
        color: #9ca3af;
        margin-left: 4px;
    }

    .plan-tagline {
        font-family: var(--font-sans);
        font-size: 0.85rem;
        color: #9ca3af;
        margin: 0;
    }

    /* Features */
    .plan-features {
        list-style: none;
        padding: 0;
        margin: 0 0 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        flex: 1;
    }

    .plan-features li {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        font-family: var(--font-sans);
        font-size: 0.9rem;
        color: #374151;
        line-height: 1.5;
    }

    :global(.dark) .plan-features li {
        color: #d1d5db;
    }

    .plan-features li svg {
        flex-shrink: 0;
        margin-top: 3px;
        color: var(--color-green-light);
    }

    :global(.dark) .plan-features li svg {
        color: var(--color-orange);
    }

    /* CTA */
    .plan-cta {
        display: block;
        width: 100%;
        text-align: center;
        padding: 0.85rem 1.5rem;
        font-family: var(--font-pop);
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .plan-cta:hover {
        transform: translateY(-2px);
    }

    .plan-cta-outline {
        background: transparent;
        color: var(--color-green-dark);
        border: 2px solid var(--color-green-dark);
    }

    .plan-cta-outline:hover {
        background: var(--color-green-dark);
        color: #fff;
        box-shadow: 0 8px 20px rgba(24, 64, 20, 0.2);
    }

    :global(.dark) .plan-cta-outline {
        color: var(--color-white);
        border-color: var(--color-white);
    }

    :global(.dark) .plan-cta-outline:hover {
        background: var(--color-white);
        color: #191919;
    }

    .plan-cta-filled {
        background: var(--color-orange);
        color: #fff;
        border: 2px solid var(--color-orange);
    }

    .plan-cta-filled:hover {
        box-shadow: 0 8px 20px rgba(185, 58, 5, 0.3);
    }
</style>
