---
import Layout from '../../layouts/Layout.astro';
import { events } from '../../data/events.js';
import '../../styles/admin-dashboard.css';
---

<Layout
    title="Dashboard comunidad — Chitaga Tech"
    description="Panel privado con metricas de la comunidad Chitaga Tech."
>
    <div class="dash-page">
        <div class="dash-hero">
            <div class="dash-hero-tag">Panel privado</div>
            <h1>Chitaga <span>Tech</span></h1>
            <p>Dashboard de la comunidad</p>
        </div>

        <div class="dash-container">
            <!-- Auth gate -->
            <section id="dash-gate" class="dash-gate">
                <form id="dash-auth-form" class="dash-auth-form" autocomplete="off">
                    <div class="dash-field">
                        <label for="dash-password">Contrasena</label>
                        <input id="dash-password" name="password" type="password" required placeholder="Clave de administrador" />
                    </div>
                    <div class="dash-field">
                        <label for="dash-event-slug">Evento</label>
                        <select id="dash-event-slug" name="eventSlug" required>
                            {events.map((event) => (
                                <option value={event.slug}>{event.title}</option>
                            ))}
                        </select>
                    </div>
                    <button type="submit" id="dash-load-btn" class="dash-btn dash-btn--primary">Ver dashboard</button>
                    <p id="dash-feedback" class="dash-feedback"></p>
                </form>
            </section>

            <!-- Dashboard content (hidden until auth) -->
            <section id="dash-content" hidden>
                <div id="dash-render"></div>
                <div class="dash-actions">
                    <button id="dash-back-btn" class="dash-btn dash-btn--outline">Cambiar evento</button>
                </div>
                <div class="dash-footer">CHITAGA TECH &middot; chitaga.tech</div>
            </section>
        </div>
    </div>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script is:inline src="/scripts/admin-dashboard.js?v=18"></script>
</Layout>
