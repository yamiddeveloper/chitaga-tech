---
import Layout from "../layouts/Layout.astro";
import '../styles/comunidad.css';
---

<Layout
    title="Comunidad WhatsApp — Chitagá Tech"
    description="Únete a nuestra comunidad de WhatsApp y recibe toda la información de primera mano: cursos, talleres, eventos y oportunidades en tecnología para Chitagá."
    image="/og-image.png"
    ogType="article"
>
    <section class="comunidad-content">
        <div class="comunidad-inner">
            <a href="/" class="comunidad-back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="comunidad-back-icon"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
            </a>

            <div class="comunidad-hero">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <h1 class="comunidad-title">Únete a nuestra comunidad de WhatsApp</h1>
                <p class="comunidad-subtitle">
                    Ahí es donde pasa todo. Cursos, talleres, eventos y oportunidades laborales. Todo de primera mano, directo a tu celular.
                </p>

                <a href="https://chat.whatsapp.com/KkSRnc4KOi7KQQNOblrRCv" target="_blank" rel="noopener noreferrer" class="comunidad-cta">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                    Unirme a la comunidad
                </a>
            </div>

            <div class="comunidad-perks">
                <div class="perks-grid">
                    <div class="perk-card">
                        <h3>Info de primera mano</h3>
                        <p>Cursos, talleres y eventos antes que nadie.</p>
                    </div>

                    <div class="perk-card">
                        <h3>Oportunidades laborales</h3>
                        <p>Ofertas de trabajo y proyectos freelance tech.</p>
                    </div>

                    <div class="perk-card">
                        <h3>Contenido exclusivo</h3>
                        <p>Tips y recursos solo para la comunidad.</p>
                    </div>

                    <div class="perk-card">
                        <h3>Aprendizaje continuo</h3>
                        <p>Resuelve dudas y aprende junto a otros.</p>
                    </div>

                    <div class="perk-card">
                        <h3>Conexión directa</h3>
                        <p>Habla con el equipo y otros miembros.</p>
                    </div>

                    <div class="perk-card">
                        <h3>Sin spam</h3>
                        <p>Solo compartimos lo que realmente importa.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
