---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Página no encontrada"
  description="Esta página no existe."
  image="/og-image.png"
>
  <section style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;text-align:center;padding:2rem;">
    <h1 style="font-size:1.5rem;margin-bottom:1rem;">Esta página no está disponible temporalmente</h1>
    <p style="color:var(--text-secondary,#666);max-width:400px;">Estamos revisando el contenido. Volverá pronto.</p>
    <a href="/" style="margin-top:1.5rem;color:var(--accent,#2563eb);">Volver al inicio</a>
  </section>
</Layout>
